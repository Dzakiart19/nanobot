modules = ["python-3.11", "nodejs-20", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Gateway"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e-send-message"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd webui && npm install && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend Gateway"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/setup-dev.sh && dzeck gateway --port 8080"
waitForPort = 8080

[[workflows.workflow]]
name = "e2e-send-message"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_PATH=node_modules DZECK_AUTH_SECRET=$(python3 -c \"import json; c=json.load(open('/root/.dzeck/config.json') if __import__('os').path.exists('/root/.dzeck/config.json') else open('/home/runner/.dzeck/config.json')); print(c['channels']['websocket']['tokenIssueSecret'])\") node e2e/test-send-message.js"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[[ports]]
localPort = 8080
externalPort = 8080
exposeLocalhost = true

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "bash scripts/start-production.sh"]
build = ["bash", "-c", "pip install ."]

[userenv]

[userenv.shared]
MONGODB_DATABASE = "dzeckbot"
OPENAI_BASE_URL = "https://chat-gateway--tmi84kzh.replit.app/v1"
SSL_CERT_FILE = "/home/runner/workspace/.pythonlibs/lib/python3.11/site-packages/certifi/cacert.pem"
REQUESTS_CA_BUNDLE = "/home/runner/workspace/.pythonlibs/lib/python3.11/site-packages/certifi/cacert.pem"
DZECK_API_BASE = "https://chat-gateway--tmi84kzh.replit.app/v1"
DZECK_MODEL = "qwen3.7-max"
