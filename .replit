modules = ["python-3.11", "nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Gateway"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e-send-message"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd webui && npm install && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend Gateway"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/setup-dev.sh && nanobot gateway --port 8080"
waitForPort = 8080

[[workflows.workflow]]
name = "e2e-send-message"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_PATH=node_modules NANOBOT_AUTH_SECRET=$(python3 -c \"import json; c=json.load(open('/root/.nanobot/config.json') if __import__('os').path.exists('/root/.nanobot/config.json') else open('/home/runner/.nanobot/config.json')); print(c['channels']['websocket']['tokenIssueSecret'])\") node e2e/test-send-message.js"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[[ports]]
localPort = 8080
externalPort = 8080
exposeLocalhost = true

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "bash scripts/start-production.sh"]
build = ["bash", "-c", "cd webui && npm install && npm run build"]

[userenv]

[userenv.shared]
NANOBOT_API_KEY = "sk-dzcxNdD2d0s7XWTliVdpxjkP-o_3yNTrezA-FILk8cXcgl34"
NANOBOT_API_BASE = "https://divine-vittoria-dzeckyete-d2996f6e.koyeb.app/v1"
NANOBOT_MODEL = "qwen3.7-max"
MONGODB_DATABASE = "dzeckbot"
